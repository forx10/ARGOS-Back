// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/argos_backend/nodejs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Tabla de turnos rotativos del usuario
model turno {
  id                  Int       @id @default(autoincrement())
  usuario_id          String    @db.VarChar(255)
  hora_inicio         String    @db.VarChar(5)   // Formato "HH:MM"
  hora_fin            String    @db.VarChar(5)   // Formato "HH:MM"
  tipo_turno          String    @db.VarChar(50)  // "6AM-2PM", "2PM-10PM", "10PM-6AM"
  fecha               DateTime  @db.Date
  activo              Boolean   @default(true)
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([usuario_id])
  @@index([fecha])
}

// Tabla de bloqueos activos
model bloqueo_activo {
  id                  Int       @id @default(autoincrement())
  usuario_id          String    @db.VarChar(255)
  apps_bloqueadas     String[]  @default([])     // Array de nombres de apps
  sitios_bloqueados   String[]  @default([])     // Array de URLs/patrones
  tiempo_inicio       DateTime  @default(now())
  tiempo_fin          DateTime
  estado              String    @db.VarChar(50)  // "activo", "pausado", "completado"
  razon               String    @db.VarChar(255) // "turno", "manual", etc
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([usuario_id])
  @@index([estado])
  @@index([tiempo_fin])
}

// Tabla de sitios bloqueados por categoría
model sitio_bloqueado {
  id                  Int       @id @default(autoincrement())
  patron_url          String    @db.VarChar(500) // Patrón o URL exacta
  categoria           String    @db.VarChar(100) // "pornografia", "redes_sociales", etc
  descripcion         String?   @db.VarChar(255)
  activo              Boolean   @default(true)
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([categoria])
  @@unique([patron_url])
}

// Tabla de alarmas programadas
model alarmas {
  id           Int      @id @default(autoincrement())
  usuario_id   String   @db.VarChar(255)
  timestamp    DateTime // Cuando se debe ejecutar
  tipo         String   @db.VarChar(50) // "recordatorio", "bloqueo", "turno"
  mensaje      String?  @db.Text
  metadata     Json?    // Datos adicionales: apps, sitios, turno_id, etc.
  ejecutada    Boolean  @default(false)
  created_at   DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
  @@index([ejecutada])
}

// Tabla de historial de comandos de voz
model comandos_voz {
  id           Int      @id @default(autoincrement())
  usuario_id   String   @db.VarChar(255)
  texto        String   @db.Text
  audio_base64 String?  @db.Text
  parsed_data  Json?    // Resultado del parseo con LLM
  timestamp    DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
}

// Tabla de notificaciones recibidas
model notificacion {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  app             String   @db.VarChar(100)   // WhatsApp, Telegram, etc
  titulo          String   @db.VarChar(500)
  texto           String   @db.Text
  remitente       String   @db.VarChar(255)
  timestamp       DateTime @default(now())
  anunciada       Boolean  @default(false)    // Si ya se leyó en voz alta
  voz_habilitada  Boolean  @default(false)    // Si esta app genera voz
  created_at      DateTime @default(now())

  @@index([usuario_id])
  @@index([app])
  @@index([anunciada])
  @@index([timestamp])
}

// Tabla de configuración del usuario
model configuracion {
  id          Int      @id @default(autoincrement())
  usuario_id  String   @db.VarChar(255)
  clave       String   @db.VarChar(255)
  valor       String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([usuario_id, clave])
  @@index([usuario_id])
}

// Tabla de archivos SD
model archivo_sd {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre          String   @db.VarChar(500)
  ruta_completa   String   @db.Text
  tipo            String   @db.VarChar(100)   // imagen, video, audio, documento
  tamano_bytes    BigInt?
  extension       String   @db.VarChar(50)
  fecha_creacion  DateTime?
  fecha_modificacion DateTime?
  indexado_en     DateTime @default(now())

  @@index([usuario_id])
  @@index([tipo])
  @@index([extension])
}

// Tabla de fotos tomadas con cámara
model foto_camara {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  ruta_archivo    String   @db.Text
  ruta_cloud      String?  @db.Text           // Si se sube a la nube
  descripcion     String?  @db.Text
  camara          String   @db.VarChar(50)    // frontal, trasera
  resolucion      String?  @db.VarChar(50)
  timestamp       DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
}
