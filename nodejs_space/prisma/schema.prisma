// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/argos_backend/nodejs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Tabla de turnos rotativos del usuario
model turno {
  id                  Int       @id @default(autoincrement())
  usuario_id          String    @db.VarChar(255)
  hora_inicio         String    @db.VarChar(5)   // Formato "HH:MM"
  hora_fin            String    @db.VarChar(5)   // Formato "HH:MM"
  tipo_turno          String    @db.VarChar(50)  // "6AM-2PM", "2PM-10PM", "10PM-6AM"
  fecha               DateTime  @db.Date
  activo              Boolean   @default(true)
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([usuario_id])
  @@index([fecha])
}

// Tabla de bloqueos activos
model bloqueo_activo {
  id                  Int       @id @default(autoincrement())
  usuario_id          String    @db.VarChar(255)
  apps_bloqueadas     String[]  @default([])     // Array de nombres de apps
  sitios_bloqueados   String[]  @default([])     // Array de URLs/patrones
  tiempo_inicio       DateTime  @default(now())
  tiempo_fin          DateTime
  estado              String    @db.VarChar(50)  // "activo", "pausado", "completado"
  razon               String    @db.VarChar(255) // "turno", "manual", etc
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([usuario_id])
  @@index([estado])
  @@index([tiempo_fin])
}

// Tabla de sitios bloqueados por categoría
model sitio_bloqueado {
  id                  Int       @id @default(autoincrement())
  patron_url          String    @db.VarChar(500) // Patrón o URL exacta
  categoria           String    @db.VarChar(100) // "pornografia", "redes_sociales", etc
  descripcion         String?   @db.VarChar(255)
  activo              Boolean   @default(true)
  creado_en           DateTime  @default(now())
  actualizado_en      DateTime  @updatedAt

  @@index([categoria])
  @@unique([patron_url])
}

// Tabla de alarmas programadas
model alarmas {
  id           Int      @id @default(autoincrement())
  usuario_id   String   @db.VarChar(255)
  timestamp    DateTime // Cuando se debe ejecutar
  tipo         String   @db.VarChar(50) // "recordatorio", "bloqueo", "turno"
  mensaje      String?  @db.Text
  metadata     Json?    // Datos adicionales: apps, sitios, turno_id, etc.
  ejecutada    Boolean  @default(false)
  created_at   DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
  @@index([ejecutada])
}

// Tabla de historial de comandos de voz
model comandos_voz {
  id           Int      @id @default(autoincrement())
  usuario_id   String   @db.VarChar(255)
  texto        String   @db.Text
  audio_base64 String?  @db.Text
  parsed_data  Json?    // Resultado del parseo con LLM
  timestamp    DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
}

// Tabla de notificaciones recibidas
model notificacion {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  app             String   @db.VarChar(100)   // WhatsApp, Telegram, etc
  titulo          String   @db.VarChar(500)
  texto           String   @db.Text
  remitente       String   @db.VarChar(255)
  timestamp       DateTime @default(now())
  anunciada       Boolean  @default(false)    // Si ya se leyó en voz alta
  voz_habilitada  Boolean  @default(false)    // Si esta app genera voz
  created_at      DateTime @default(now())

  @@index([usuario_id])
  @@index([app])
  @@index([anunciada])
  @@index([timestamp])
}

// Tabla de configuración del usuario
model configuracion {
  id          Int      @id @default(autoincrement())
  usuario_id  String   @db.VarChar(255)
  clave       String   @db.VarChar(255)
  valor       String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([usuario_id, clave])
  @@index([usuario_id])
}

// Tabla de archivos SD
model archivo_sd {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre          String   @db.VarChar(500)
  ruta_completa   String   @db.Text
  tipo            String   @db.VarChar(100)   // imagen, video, audio, documento
  tamano_bytes    BigInt?
  extension       String   @db.VarChar(50)
  fecha_creacion  DateTime?
  fecha_modificacion DateTime?
  indexado_en     DateTime @default(now())

  @@index([usuario_id])
  @@index([tipo])
  @@index([extension])
}

// Tabla de fotos tomadas con cámara
model foto_camara {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  ruta_archivo    String   @db.Text
  ruta_cloud      String?  @db.Text           // Si se sube a la nube
  descripcion     String?  @db.Text
  camara          String   @db.VarChar(50)    // frontal, trasera
  resolucion      String?  @db.VarChar(50)
  timestamp       DateTime @default(now())

  @@index([usuario_id])
  @@index([timestamp])
}

// Tabla de solicitudes de actualización (Self-Update)
model solicitud_actualizacion {
  id                    Int      @id @default(autoincrement())
  usuario_id            String   @db.VarChar(255)
  tipo_comando          String   @db.VarChar(100)
  descripcion           String   @db.Text
  razon                 String   @db.Text
  estado                String   @db.VarChar(50)   // pendiente, aprobado, rechazado
  opcion_seleccionada   String?  @db.VarChar(255)
  notas                 String?  @db.Text
  creado_en             DateTime @default(now())
  actualizado_en        DateTime @updatedAt

  @@index([usuario_id])
  @@index([estado])
  @@index([creado_en])
}

// Tabla de capturas de pantalla (Screen Vision)
model captura_pantalla {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  imagen_base64   String   @db.Text
  contexto        String?  @db.Text
  analizada       Boolean  @default(false)
  analisis        String?  @db.Text
  sugerencias     String[]  @default([])
  capturada_en    DateTime @default(now())
  analizada_en    DateTime?

  @@index([usuario_id])
  @@index([analizada])
  @@index([capturada_en])
}

// Tabla de contactos de emergencia
model contacto_emergencia {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre          String   @db.VarChar(255)
  telefono        String   @db.VarChar(20)
  tipo            String   @db.VarChar(50)   // "policia", "familiar", "amigo", etc
  activo          Boolean  @default(true)
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@index([usuario_id])
  @@index([tipo])
}

// Tabla de incidentes SOS
model incidente_sos {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  latitud         Float?
  longitud        Float?
  tipo_emergencia String   @db.VarChar(100)  // "policia", "emergencia medica", etc
  contactos_contactados String[] @default([])  // Nombres de contactos llamados
  llamadas_realizadas Int     @default(0)
  mensajes_enviados Int     @default(0)
  estado          String   @db.VarChar(50)   // "activo", "resuelto", "cancelado"
  grabacion_audio Boolean  @default(false)
  creado_en       DateTime @default(now())
  resuelto_en     DateTime?

  @@index([usuario_id])
  @@index([estado])
  @@index([creado_en])
}

// Tabla de geofences (ubicaciones)
model geofence {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre          String   @db.VarChar(255)  // "Casa", "Gimnasio", "Trabajo"
  latitud         Float
  longitud        Float
  radio           Float    @default(500)     // radio en metros
  recordatorios   String[] @default([])      // tareas a recordar al llegar
  tipo_bloqueo    String?  @db.VarChar(100) // "focus", "ninguno", etc
  duracion_bloqueo Int?                       // en minutos
  activo          Boolean  @default(true)
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@index([usuario_id])
  @@index([nombre])
}

// Tabla de sesiones de Focus Mode
model sesion_focus {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  hora_inicio     DateTime @default(now())
  hora_fin        DateTime
  apps_bloqueadas String[] @default([])
  sitios_bloqueados String[] @default([])
  motivo          String?  @db.VarChar(255)  // "estudio", "trabajo", "descanso"
  completado      Boolean  @default(false)
  estadisticas    Json?    // {appsEvitadas: [], tiempoAhorrado: ""}

  @@index([usuario_id])
  @@index([hora_inicio])
  @@index([completado])
}

// Tabla de tareas
model tarea {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  titulo          String   @db.VarChar(500)
  descripcion     String?  @db.Text
  prioridad       String   @db.VarChar(50)   // "baja", "media", "alta"
  completada      Boolean  @default(false)
  ubicacion       String?  @db.VarChar(255)  // geofence asociado
  fecha_vencimiento DateTime?
  creada_en       DateTime @default(now())
  completada_en   DateTime?

  @@index([usuario_id])
  @@index([completada])
  @@index([prioridad])
}

// Tabla de diagnósticos del dispositivo
model diagnostico_dispositivo {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  timestamp       DateTime @default(now())
  ram_total_mb    Int?
  ram_disponible_mb Int?
  cpu_porcentaje  Float?
  temperatura     Float?   // en grados Celsius
  bateria_porcent Float?
  almacenamiento_libre_mb BigInt?
  problemas       String[] @default([])  // lista de problemas detectados
  recomendaciones String[] @default([])

  @@index([usuario_id])
  @@index([timestamp])
}

// Tabla de monitoreo de red
model monitor_red {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  timestamp       DateTime @default(now())
  nombre_wifi     String?  @db.VarChar(255)
  seguridad_wifi  String?  @db.VarChar(100)  // "WPA3", "WPA2", "WEP", "Abierta"
  es_seguro       Boolean  @default(false)
  sitio_visitado  String?  @db.VarChar(500)
  es_phishing     Boolean  @default(false)
  recomendacion   String?  @db.Text

  @@index([usuario_id])
  @@index([timestamp])
}

// ================================
// PERFIL DE USUARIO Y PERSONALIZACIÓN
// ================================
model perfil_usuario {
  id                  Int      @id @default(autoincrement())
  usuario_id          String   @unique @db.VarChar(255)
  nombre_usuario      String   @db.VarChar(255)        // "Luis", "María", etc.
  nombre_asistente    String   @default("ARGOS") @db.VarChar(255)  // "Jarvis", "Friday", etc.
  wake_word           String   @default("ARGOS") @db.VarChar(255)  // Palabra de activación
  genero_voz          String   @default("mujer") @db.VarChar(10)   // "hombre" o "mujer"
  idioma              String   @default("es") @db.VarChar(10)
  saludo_personalizado String? @db.Text                // "Hola Luis, ¿en qué te ayudo?"
  personalidad        String   @default("profesional") @db.VarChar(50) // "profesional", "amigable", "formal"
  configurado         Boolean  @default(false)          // Si ya completó el onboarding
  creado_en           DateTime @default(now())
  actualizado_en      DateTime @updatedAt

  @@index([usuario_id])
}

// ================================
// PC BRIDGE - Integración con Computadora
// ================================
model pc_conexion {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre_pc       String   @db.VarChar(255)           // "Mi PC Trabajo", "Laptop Casa"
  pc_id           String   @unique @db.VarChar(255)   // Identificador único del PC
  estado          String   @default("desconectado") @db.VarChar(50)  // "conectado", "desconectado"
  ultimo_ping     DateTime?
  ip_local        String?  @db.VarChar(50)
  sistema_operativo String? @db.VarChar(100)
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@index([usuario_id])
  @@index([pc_id])
}

model sitio_habitual {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  nombre          String   @db.VarChar(255)           // "Gmail", "YouTube", "GitHub"
  url             String   @db.Text                    // "https://gmail.com"
  categoria       String   @default("general") @db.VarChar(100) // "trabajo", "personal", "entretenimiento"
  orden           Int      @default(0)                 // Orden de apertura
  abrir_al_inicio Boolean  @default(false)             // Abrir automáticamente al conectar PC
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@index([usuario_id])
  @@index([categoria])
}

model comando_pc {
  id              Int      @id @default(autoincrement())
  usuario_id      String   @db.VarChar(255)
  pc_id           String   @db.VarChar(255)
  tipo_comando    String   @db.VarChar(100)           // "abrir_sitios", "abrir_app", "ejecutar", "escribir"
  parametros      Json                                  // {urls: [...], app: "code", texto: "..."}
  estado          String   @default("pendiente") @db.VarChar(50) // "pendiente", "ejecutado", "error"
  resultado       String?  @db.Text
  creado_en       DateTime @default(now())
  ejecutado_en    DateTime?

  @@index([usuario_id])
  @@index([pc_id])
  @@index([estado])
}
